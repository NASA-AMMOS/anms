# Default environment variables for ANMS integration testing.
# Override these as needed; docker-compose and Playwright tests read them.

# ─── Docker Image ───────────────────────────────────────────────────────────
# Set these if building custom images or using a different registry.
# Docker Compose will use: ${DOCKER_IMAGE_PREFIX}anms-core:${DOCKER_IMAGE_TAG}
#
# Example for GitHub Container Registry:
#   DOCKER_IMAGE_PREFIX=ghcr.io/nasa-ammos/anms/
#
DOCKER_IMAGE_PREFIX=
DOCKER_IMAGE_TAG=latest

# ─── Database ───────────────────────────────────────────────────────────────
# Postgres credentials for the anms-core and amp-manager services.
# These match the defaults in docker-compose-full.yml but are set here
# so you don't have to retype them.
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=amp_core

# ─── ION / AMP Manager ─────────────────────────────────────────────────────
# Port the amp-manager HTTP API is exposed on inside the container.
ION_MGR_PORT=8089

# Unix socket directory shared between amp-manager and ion-manager.
# This must match the volume mount path.
CTR_SOCKDIR=/var/tmp/nm

# ─── Playwright Test Configuration ──────────────────────────────────────────
# Base URL of the anms-ui service after the stack is running.
BASE_URL=http://localhost:9030

# Username for header-based auth bypass (see main.js preMainPageHandler).
# The Angular UI has no login page; auth is provided via x-remote-user header.
TEST_USERNAME=test
