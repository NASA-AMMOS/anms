# Integration test environment defaults.
# Copy to .env.local and edit for local overrides.

# ─── Image settings ───────────────────────────────────────────────────────
DOCKER_IMAGE_PREFIX=ghcr.io/nasa-ammos/anms/
DOCKER_IMAGE_TAG=latest

# ─── Database ─────────────────────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=amp_core

# ─── Ports ────────────────────────────────────────────────────────────────
AUTHNZ_PORT=80
OPENSEARCH_PORT1=9200
OPENSEARCH_PORT2=9600
OPENSEARCH_DASH_PORT=5601
ADMINER_PORT=8080
RENDERER_PORT=8081
ION_MGR_PORT=8089

# ─── Sockdir ──────────────────────────────────────────────────────────────
HOST_SOCKDIR=/var/tmp/nm
CTR_SOCKDIR=/var/tmp/nm
